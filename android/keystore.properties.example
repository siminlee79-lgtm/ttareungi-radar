# Copy to android/keystore.properties and fill in your own values.
# keystore.properties is gitignored — never commit the real one.
#
# storeFile: absolute path to the upload keystore. Keep the .jks itself
# outside the repo so it can never be staged by accident.

storeFile=C:/Users/YOUR_NAME/Documents/keystores/ttareungi-radar-upload.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=ttareungi-radar-upload
keyPassword=YOUR_KEY_PASSWORD
